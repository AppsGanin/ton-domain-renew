# Optional TonAPI key (https://tonconsole.com). Keyless requests work but are
# rate-limited. NOTE: any VITE_* value is bundled into the public static site,
# so only set this if you're fine with the key being visible to visitors.
VITE_TONAPI_KEY=
VITE_TONCONNECT_MANIFEST_URL=
VITE_GITHUB_REPO_URL=
